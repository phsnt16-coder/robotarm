from MOTOR_CONTROL import RobotArm


def wait(msg):
    input(f"\n{msg}\nEnter 입력: ")


def test_shoulder_direction(arm):
    """
    Shoulder Pair(ID2/ID3) 방향 점검.
    동기화 구조는 유지하고, 각도 증가 시 실제 어깨가 어느 방향으로 움직이는지 관찰한다.

    판단:
    - 20 -> 60 -> 100으로 갈 때 원하는 방향이면 현재 move_sync_2_3 정상
    - 반대 방향이면 MOTOR_CONTROL.py의 move_sync_2_3()에서 pos2/pos3를 서로 교환
    """
    print("\n" + "=" * 50)
    print("[TEST] Shoulder ID2/ID3 방향 점검")
    print("=" * 50)

    test_angles = [20, 60, 100, 60]

    for deg in test_angles:
        wait(f"Shoulder {deg}도 이동")
        arm.move_sync_2_3(deg)

    print("\n[판단]")
    print("각도 증가 20 -> 60 -> 100에서 원하는 방향으로 움직이면 정상")
    print("반대로 움직이면 move_sync_2_3() 내부를 아래처럼 수정")
    print("기존: pos2 = logical_pos / pos3 = reverse_pos(logical_pos)")
    print("수정: pos2 = reverse_pos(logical_pos) / pos3 = logical_pos")


def test_wrist_direction(arm):
    """
    Wrist(ID6) 방향 점검.

    판단:
    - 70 -> 110 -> 150으로 갈 때 원하는 방향이면 현재 move_single_6 정상
    - 반대 방향이면 move_single_6()에서 reverse_pos(deg_to_pos(deg)) 적용
    """
    print("\n" + "=" * 50)
    print("[TEST] Wrist ID6 방향 점검")
    print("=" * 50)

    test_angles = [70, 110, 150, 110]

    for deg in test_angles:
        wait(f"Wrist ID6 {deg}도 이동")
        arm.move_single_6(deg)

    print("\n[판단]")
    print("각도 증가 70 -> 110 -> 150에서 원하는 방향으로 움직이면 정상")
    print("반대로 움직이면 move_single_6() 내부를 아래처럼 수정")
    print("기존: pos = deg_to_pos(deg)")
    print("수정: pos = reverse_pos(deg_to_pos(deg))")


def test_combined_small_motion(arm):
    """
    Shoulder와 Wrist를 작은 범위에서 같이 움직여 실제 링크 방향 확인.
    """
    print("\n" + "=" * 50)
    print("[TEST] Shoulder + Wrist 조합 방향 점검")
    print("=" * 50)

    sequence = [
        (60, 110),
        (40, 90),
        (60, 110),
        (80, 130),
        (60, 110),
    ]

    for shoulder_deg, wrist_deg in sequence:
        wait(f"Shoulder={shoulder_deg}, Wrist={wrist_deg} 이동")
        arm.move_sync_2_3(shoulder_deg)
        arm.move_single_6(wrist_deg)

    print("\n[판단]")
    print("조합 동작에서 URDF 이미지와 실제 링크 방향이 같은지 확인")
    print("Shoulder만 반대면 move_sync_2_3 수정")
    print("Wrist만 반대면 move_single_6 수정")
    print("둘 다 반대면 둘 다 수정")


def main():
    arm = RobotArm()

    if not arm.open_robot_port():
        print("[오류] 로봇 포트 연결 실패")
        return

    try:
        print("\n===== Shoulder / Wrist 방향 점검 테스트 =====")
        print("주의: 테스트 전 로봇 주변 충돌 가능 물체를 치우세요.")
        print("각 단계는 Enter를 눌러야 진행됩니다.")

        print("\n테스트 선택")
        print("1 : Shoulder ID2/ID3 방향만 점검")
        print("2 : Wrist ID6 방향만 점검")
        print("3 : Shoulder + Wrist 조합 점검")
        print("4 : 전체 순서대로 점검")
        print("q : 종료")

        mode = input("\n선택: ").strip().lower()

        if mode == "q":
            return

        if mode == "1":
            test_shoulder_direction(arm)

        elif mode == "2":
            test_wrist_direction(arm)

        elif mode == "3":
            test_combined_small_motion(arm)

        else:
            test_shoulder_direction(arm)
            test_wrist_direction(arm)
            test_combined_small_motion(arm)

    finally:
        arm.close_robot()
        print("\n[TEST 종료]")


if __name__ == "__main__":
    main()
