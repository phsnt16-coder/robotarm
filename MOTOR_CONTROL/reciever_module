import time

from robot_ik import RobotIKController
from MOTOR_CONTROL_centered_fast import RobotArm


URDF_PATH = "mybot_skeleton_logical_center.urdf"


def parse_packet(packet_data):
    if packet_data.get("cmd") == "shutdown":
        return "shutdown", None, None, None

    label = packet_data["label"]
    pick = tuple(map(float, packet_data["pick"]))
    load = tuple(map(float, packet_data["load"]))
    angle = float(packet_data.get("angle", 0.0))

    return label, pick, load, angle


def execute_sequence_1_2_3_4_3_6_7(arm, ik_solver, label, pick, load):
    px, py, pz = pick
    lx, ly, lz = load

    print("\n[RECEIVER] centered 시퀀스 시작")

    arm.pose_1_base()
    arm.pose_2_pick_ready()
    arm.pose_3_go_to_place()

    # Pick IK는 한 번만 계산한다.
    pick_ik = ik_solver.calculate_pick_ik(
        [px, py, pz],
        label=label,
    )

    arm.act_pick(
        box_type=label,
        ik_angles=pick_ik,
    )

    arm.vacuum_on()
    time.sleep(0.2)

    arm.pose_3_go_to_place()
    arm.pose_6_place_origin()

    place_origin_pose = arm.get_current_pose()

    # Place IK도 한 번만 계산한다.
    place_ik = ik_solver.calculate_place_ik(
        [lx, ly, lz],
        place_origin_pose_deg=place_origin_pose,
    )

    arm.act_place(
        ik_angles=place_ik,
    )

    arm.vacuum_off()
    time.sleep(0.2)

    print("[RECEIVER] centered 시퀀스 완료")


def motor_control_receiver(q):
    ik_solver = RobotIKController(URDF_PATH)
    arm = RobotArm()

    if not arm.open_robot_port():
        print("[RECEIVER] 로봇 포트 연결 실패")
        return

    arm.save_initial_positions()

    print("\n[RECEIVER] centered 가동 시작 - Queue 대기")

    try:
        while True:
            packet_data = q.get()

            label, pick, load, angle = parse_packet(packet_data)

            if label == "shutdown":
                print("[RECEIVER] 종료 명령 수신")
                break

            print(
                f"\n[RECEIVER] {label} | "
                f"Pick={pick} | Load={load} | Angle={angle:.1f}"
            )

            execute_sequence_1_2_3_4_3_6_7(
                arm=arm,
                ik_solver=ik_solver,
                label=label,
                pick=pick,
                load=load,
            )

    except KeyboardInterrupt:
        print("\n[RECEIVER] 사용자 중단")

    except Exception as e:
        print(f"\n[RECEIVER] 오류: {e}")

    finally:
        try:
            arm.vacuum_off()
        except Exception:
            pass

        arm.close_robot()
        print("[RECEIVER] 종료 완료")


if __name__ == "__main__":
    print("이 파일은 multiprocessing.Process target으로 사용합니다.")
