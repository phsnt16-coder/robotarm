import os
import inspect
import time

import robot_ik
import MOTOR_CONTROL
from robot_ik import RobotIKController
from MOTOR_CONTROL import RobotArm


URDF_PATH = "mybot.urdf"


def print_section(title):
    print("\n" + "=" * 70)
    print(title)
    print("=" * 70)


def has_label_arg(method):
    try:
        sig = inspect.signature(method)
        return "label" in sig.parameters
    except Exception:
        return False


def call_pick_ik(ik_solver, pick, label):
    if has_label_arg(ik_solver.calculate_pick_ik):
        return ik_solver.calculate_pick_ik(pick, label=label)

    print("[WARN] calculate_pick_ik()가 label 인자를 지원하지 않습니다.")
    return ik_solver.calculate_pick_ik(pick)


def call_pick_joints(ik_solver, pick, label):
    if hasattr(ik_solver, "calculate_pick_joints"):
        if has_label_arg(ik_solver.calculate_pick_joints):
            return ik_solver.calculate_pick_joints(pick, label=label)

        print("[WARN] calculate_pick_joints()가 label 인자를 지원하지 않습니다.")
        return ik_solver.calculate_pick_joints(pick)

    return None


def check_import_and_settings():
    print_section("1. IMPORT / 설정 확인")

    print(f"[PATH] 현재 작업 폴더      : {os.getcwd()}")
    print(f"[PATH] robot_ik.py        : {robot_ik.__file__}")
    print(f"[PATH] MOTOR_CONTROL.py   : {MOTOR_CONTROL.__file__}")

    ik = RobotIKController(URDF_PATH)

    print("\n[robot_ik 설정]")
    print(f"calculate_pick_ik label 지원     : {has_label_arg(ik.calculate_pick_ik)}")

    if hasattr(ik, "calculate_pick_joints"):
        print(f"calculate_pick_joints label 지원 : {has_label_arg(ik.calculate_pick_joints)}")

    for attr in [
        "PICK_Z_OFFSET_BY_LABEL",
        "GRIPPER_TCP_LENGTH_MM",
        "SERVO_DIRECTIONS",
        "PICK_ORIGIN_POSE_DEG",
        "PLACE_ORIGIN_POSE_DEG",
    ]:
        if hasattr(ik, attr):
            print(f"{attr}: {getattr(ik, attr)}")
        else:
            print(f"{attr}: 없음")

    return ik


def test_ik_values_change(ik_solver):
    print_section("2. IK 계산값 변화 확인")

    test_cases = [
        ("A_1", [120.0, 50.0, 250.0]),
        ("A_1", [200.0, 100.0, 250.0]),
        ("B_8", [120.0, 50.0, 250.0]),
    ]

    results = []

    for label, pick in test_cases:
        print("\n" + "-" * 50)
        print(f"[TEST] label={label}, pick={pick}")

        joints = call_pick_joints(ik_solver, pick, label)
        angles = call_pick_ik(ik_solver, pick, label)

        print("[RESULT] motor_angles:")
        print(angles)

        results.append((label, pick, angles))

        if joints is not None:
            print("[RESULT] raw joints:")
            for i, joint in enumerate(joints):
                print(f"  joints[{i}] = {joint}")

    print("\n[판단 기준]")
    print("- 서로 다른 Pick 좌표에서 deg23/deg45/deg6 중 하나라도 달라져야 정상")
    print("- A_1과 B_8에서 Z offset이 다르면 IK 결과도 달라질 수 있음")

    return results


def monkey_patch_trace_methods(arm):
    """
    MOTOR_CONTROL.py 파일 자체는 수정하지 않고,
    실행 중인 arm 객체에만 디버그 wrapper를 붙인다.
    """
    print_section("3. act_pick / smooth_move_all_pose 전달값 추적 패치")

    original_act_pick = arm.act_pick
    original_smooth = arm.smooth_move_all_pose

    def traced_act_pick(box_type="A_1", ik_angles=None):
        print("\n[TRACE] act_pick() 수신")
        print(f"box_type  : {box_type}")
        print(f"ik_angles : {ik_angles}")
        return original_act_pick(box_type=box_type, ik_angles=ik_angles)

    def traced_smooth(target_deg1, target_deg23, target_deg45, target_deg6, target_deg7):
        print("\n[TRACE] smooth_move_all_pose() 최종 목표각")
        print(f"target_deg1  : {target_deg1}")
        print(f"target_deg23 : {target_deg23}")
        print(f"target_deg45 : {target_deg45}")
        print(f"target_deg6  : {target_deg6}")
        print(f"target_deg7  : {target_deg7}")
        return original_smooth(target_deg1, target_deg23, target_deg45, target_deg6, target_deg7)

    arm.act_pick = traced_act_pick
    arm.smooth_move_all_pose = traced_smooth

    print("[OK] arm 객체에 임시 trace patch 적용 완료")
    print("[INFO] 파일 자체는 수정하지 않습니다.")


def test_forced_act_pick(arm):
    print_section("4. 강제 IK dict로 act_pick 직접 테스트")

    forced_ik = {
        "deg1": 0.0,
        "deg23": 130.0,
        "deg45": 40.0,
        "deg6": 180.0,
        "deg7": 0.0,
    }

    print("[강제 입력 IK]")
    print(forced_ik)

    print("\n[주의]")
    print("이 테스트는 실제 모터를 움직입니다.")
    print("어깨가 130도, 손목이 180도 방향으로 움직이는지 확인하세요.")
    print("움직이면 MOTOR_CONTROL.act_pick 경로는 정상입니다.")
    print("안 움직이면 act_pick/smooth_move_all_pose 또는 모터 제어 경로 문제입니다.")

    confirm = input("\n실제 강제 act_pick 테스트 실행? (y/n): ").strip().lower()

    if confirm != "y":
        print("[SKIP] 강제 act_pick 테스트 생략")
        return

    arm.act_pick(
        box_type="A_1",
        ik_angles=forced_ik,
    )


def test_real_ik_to_act_pick(ik_solver, arm):
    print_section("5. 실제 IK 계산값 → act_pick 전달 테스트")

    label = input("박스 라벨 입력(A_1/B_3/B_8): ").strip()

    if not label:
        label = "A_1"

    px = float(input("Pick X mm: "))
    py = float(input("Pick Y mm: "))
    pz = float(input("Pick Z mm: "))

    pick = [px, py, pz]

    print("\n[입력]")
    print(f"label : {label}")
    print(f"pick  : {pick}")

    angles = call_pick_ik(ik_solver, pick, label)

    print("\n[IK 계산 결과]")
    print(angles)

    print("\n[주의]")
    print("이 테스트는 실제 모터를 움직입니다.")
    confirm = input("이 IK 값으로 act_pick 실행? (y/n): ").strip().lower()

    if confirm != "y":
        print("[SKIP] 실제 IK act_pick 테스트 생략")
        return

    arm.pose_3_go_to_place()
    time.sleep(0.5)

    arm.act_pick(
        box_type=label,
        ik_angles=angles,
    )


def main():
    print_section("IK 값 미반영 원인 추적 테스트")

    ik_solver = check_import_and_settings()
    test_ik_values_change(ik_solver)

    arm = RobotArm()

    if not arm.open_robot_port():
        print("[ERROR] 로봇 포트 연결 실패")
        return

    try:
        arm.save_initial_positions()
        monkey_patch_trace_methods(arm)

        while True:
            print("\n메뉴")
            print("1 : 강제 IK dict로 act_pick 직접 테스트")
            print("2 : 실제 IK 계산값으로 act_pick 테스트")
            print("3 : IK 계산값 변화 재확인")
            print("4 : 초기 자세 복귀")
            print("q : 종료")

            mode = input("\n선택: ").strip().lower()

            if mode == "q":
                break

            if mode == "1":
                test_forced_act_pick(arm)

            elif mode == "2":
                test_real_ik_to_act_pick(ik_solver, arm)

            elif mode == "3":
                test_ik_values_change(ik_solver)

            elif mode == "4":
                if hasattr(arm, "return_to_initial"):
                    arm.return_to_initial()
                else:
                    arm.pose_1_base()

            else:
                print("[INFO] 잘못된 입력")

    finally:
        try:
            if hasattr(arm, "return_to_initial"):
                arm.return_to_initial()
        except Exception as e:
            print(f"[RESET WARN] {e}")

        arm.close_robot()
        print("\n[TEST 종료]")


if __name__ == "__main__":
    main()
