<?xml version="1.0"?>
<robot name="packing_robot_skeleton_g_pose_ik">

  <!--
    IK calculation URDF with ㄱ-shape default pose.
    Unit: meter

    Purpose:
    - This URDF is intended for IK calculation.
    - Zero joint state of this URDF represents the robot's Pick IK origin posture.
    - Motor-side origin posture remains:
        deg1  = 0
        deg23 = 60
        deg45 = 40
        deg6  = 110
        deg7  = 0

    Dimensions:
    - Ground -> Base reference height      : 0.095 m
    - Base -> Shoulder                     : 0.040 m
    - Shoulder -> Elbow                    : 0.120 m
    - Elbow -> Gripper joint               : 0.160 m
    - Gripper length                       : 0.060 m

    Default ㄱ-pose fixed offsets:
    - Shoulder origin rpy X = 60 deg  = 1.047198 rad
    - Elbow origin rpy X    = 40 deg  = 0.698132 rad
    - Wrist origin rpy X    = 110 deg = 1.919862 rad
  -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0475"/>
      <geometry>
        <box size="0.080 0.080 0.095"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.0475"/>
      <geometry>
        <box size="0.080 0.080 0.095"/>
      </geometry>
    </collision>
  </link>

  <link name="link1_base_to_shoulder">
    <visual>
      <origin xyz="0 0 0.020"/>
      <geometry>
        <box size="0.040 0.040 0.040"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.020"/>
      <geometry>
        <box size="0.040 0.040 0.040"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint1_base_yaw_id1" type="revolute">
    <parent link="base_link"/>
    <child link="link1_base_to_shoulder"/>
    <origin xyz="0 0 0.095" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="20" velocity="2.0"/>
  </joint>

  <link name="link23_shoulder_to_elbow">
    <visual>
      <origin xyz="0 0 0.060"/>
      <geometry>
        <box size="0.025 0.025 0.120"/>
      </geometry>
      <material name="blue_gray">
        <color rgba="0.35 0.45 0.55 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.060"/>
      <geometry>
        <box size="0.025 0.025 0.120"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint23_shoulder_pair_id2_id3" type="revolute">
    <parent link="link1_base_to_shoulder"/>
    <child link="link23_shoulder_to_elbow"/>
    <origin xyz="0 0 0.040" rpy="1.047198 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="15" velocity="1.5"/>
  </joint>

  <link name="link45_elbow_to_wrist">
    <visual>
      <origin xyz="0 0 0.080"/>
      <geometry>
        <box size="0.022 0.022 0.160"/>
      </geometry>
      <material name="steel">
        <color rgba="0.45 0.45 0.45 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.080"/>
      <geometry>
        <box size="0.022 0.022 0.160"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint45_elbow_pair_id4_id5" type="revolute">
    <parent link="link23_shoulder_to_elbow"/>
    <child link="link45_elbow_to_wrist"/>
    <origin xyz="0 0 0.120" rpy="0.698132 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="15" velocity="1.5"/>
  </joint>

  <link name="link6_wrist_to_gripper_joint">
    <visual>
      <origin xyz="0 0 0.030"/>
      <geometry>
        <box size="0.020 0.020 0.060"/>
      </geometry>
      <material name="black">
        <color rgba="0.05 0.05 0.05 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.030"/>
      <geometry>
        <box size="0.020 0.020 0.060"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint6_wrist_id6" type="revolute">
    <parent link="link45_elbow_to_wrist"/>
    <child link="link6_wrist_to_gripper_joint"/>
    <origin xyz="0 0 0.160" rpy="1.919862 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.6" upper="2.6" effort="12" velocity="1.5"/>
  </joint>

  <link name="link7_gripper_tcp">
    <visual>
      <origin xyz="0 0 0.030"/>
      <geometry>
        <box size="0.015 0.015 0.060"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.030"/>
      <geometry>
        <box size="0.015 0.015 0.060"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint7_gripper_rotation_id7" type="revolute">
    <parent link="link6_wrist_to_gripper_joint"/>
    <child link="link7_gripper_tcp"/>
    <origin xyz="0 0 0.060" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="20" velocity="2.0"/>
  </joint>

</robot>
