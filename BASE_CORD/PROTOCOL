#include <Arduino.h>

#define START_BYTE 0xAA
#define END_BYTE   0xFF

#define ACK_START  0xAC
#define ACK_END    0xCA
#define ACK_OK     0x01
#define ACK_FAIL   0x00

#define CMD_SET_PICK_PLACE 0x01
#define CMD_START          0x02
#define CMD_STOP           0x03
#define CMD_GO_HOME        0x04
#define CMD_GO_READY       0x05
#define CMD_VAC_ON         0x06
#define CMD_VAC_OFF        0x07
#define CMD_SET_SPEED      0x08
#define CMD_MOVE_SERVO     0x09
#define CMD_RUN_POSE       0x0A
#define CMD_GET_STATUS     0x0B

#define SERVO_COUNT 7
#define VACUUM_PIN 5

#define PACKET_MAX_SIZE 19

#define STATE_IDLE        0
#define STATE_MOVE_GRASP  1
#define STATE_VAC_ON      2
#define STATE_LIFT        3
#define STATE_MOVE_PLACE  4
#define STATE_VAC_OFF     5
#define STATE_DONE        6
#define STATE_STOP        7
#define STATE_HOME        8
#define STATE_READY       9

#define POSE_HOME  0
#define POSE_READY 1
#define POSE_LIFT  2
#define POSE_COUNT 3

int current_pos[SERVO_COUNT] = {500, 500, 500, 500, 500, 500, 0};
int target_pos[SERVO_COUNT]  = {500, 500, 500, 500, 500, 500, 0};
int speed_val[SERVO_COUNT]   = {2, 2, 2, 2, 2, 2, 1};

uint8_t box_type = 0;
uint8_t rot_z = 0;

int gx = 0, gy = 0, gz = 0;
int px = 0, py = 0, pz = 0;
int grasp_angle = 0;

bool vacuum_state = false;
int state = STATE_IDLE;
unsigned long state_start_time = 0;

int pose_table[POSE_COUNT][SERVO_COUNT] = {
  {500, 500, 500, 500, 500, 500, 0},
  {500, 560, 560, 440, 440, 500, 0},
  {500, 480, 480, 380, 380, 500, 0}
};

uint8_t rx_buffer[PACKET_MAX_SIZE];
uint8_t rx_index = 0;
uint8_t expected_length = 0;
bool receiving = false;

int readU16(uint8_t low, uint8_t high) {
  return ((int)high << 8) | low;
}

void sendAck(uint8_t cmd, uint8_t status) {
  uint8_t ack[4] = {ACK_START, cmd, status, ACK_END};
  Serial.write(ack, 4);
}

uint8_t getPacketLength(uint8_t cmd) {
  switch (cmd) {
    case CMD_SET_PICK_PLACE:
      return 19;

    case CMD_SET_SPEED:
    case CMD_MOVE_SERVO:
    case CMD_RUN_POSE:
      return 6;

    case CMD_START:
    case CMD_STOP:
    case CMD_GO_HOME:
    case CMD_GO_READY:
    case CMD_VAC_ON:
    case CMD_VAC_OFF:
    case CMD_GET_STATUS:
      return 3;

    default:
      return 0;
  }
}

void setState(int new_state) {
  state = new_state;
  state_start_time = millis();
}

void setup() {
  Serial.begin(115200);
  pinMode(VACUUM_PIN, OUTPUT);
  digitalWrite(VACUUM_PIN, LOW);
}

void loop() {
  receivePacket();
  processState();
  updateServo();
  updateVacuum();
}

void receivePacket() {
  while (Serial.available() > 0) {
    uint8_t b = (uint8_t)Serial.read();

    if (!receiving) {
      if (b == START_BYTE) {
        receiving = true;
        rx_index = 0;
        expected_length = 0;
        rx_buffer[rx_index++] = b;
      }
      continue;
    }

    rx_buffer[rx_index++] = b;

    if (rx_index == 2) {
      expected_length = getPacketLength(rx_buffer[1]);

      if (expected_length == 0 || expected_length > PACKET_MAX_SIZE) {
        sendAck(rx_buffer[1], ACK_FAIL);
        receiving = false;
        rx_index = 0;
        expected_length = 0;
        continue;
      }
    }

    if (expected_length > 0 && rx_index == expected_length) {
      if (rx_buffer[expected_length - 1] == END_BYTE) {
        handlePacket(rx_buffer, expected_length);
      } else {
        sendAck(rx_buffer[1], ACK_FAIL);
      }

      receiving = false;
      rx_index = 0;
      expected_length = 0;
    }

    if (rx_index >= PACKET_MAX_SIZE) {
      receiving = false;
      rx_index = 0;
      expected_length = 0;
    }
  }
}

void handlePacket(uint8_t *packet, uint8_t length) {
  uint8_t cmd = packet[1];

  switch (cmd) {
    case CMD_SET_PICK_PLACE:
      if (length == 19) {
        setPickPlaceData(packet);
        sendAck(cmd, ACK_OK);
      } else {
        sendAck(cmd, ACK_FAIL);
      }
      break;

    case CMD_START:
    case CMD_STOP:
    case CMD_GO_HOME:
    case CMD_GO_READY:
    case CMD_VAC_ON:
    case CMD_VAC_OFF:
    case CMD_GET_STATUS:
      if (length == 3) {
        processSimpleCommand(cmd);
        sendAck(cmd, ACK_OK);
      } else {
        sendAck(cmd, ACK_FAIL);
      }
      break;

    case CMD_SET_SPEED:
    case CMD_MOVE_SERVO:
    case CMD_RUN_POSE:
      if (length == 6) {
        processValueCommand(packet);
        sendAck(cmd, ACK_OK);
      } else {
        sendAck(cmd, ACK_FAIL);
      }
      break;

    default:
      sendAck(cmd, ACK_FAIL);
      break;
  }
}

void setPickPlaceData(uint8_t *p) {
  box_type = p[2];
  rot_z = p[3];

  gx = readU16(p[4], p[5]);
  gy = readU16(p[6], p[7]);
  gz = readU16(p[8], p[9]);

  px = readU16(p[10], p[11]);
  py = readU16(p[12], p[13]);
  pz = readU16(p[14], p[15]);

  grasp_angle = readU16(p[16], p[17]);

  setState(STATE_IDLE);
}

void processSimpleCommand(uint8_t cmd) {
  switch (cmd) {
    case CMD_START:
      setState(STATE_MOVE_GRASP);
      break;

    case CMD_STOP:
      stopAll();
      break;

    case CMD_GO_HOME:
      goHome();
      break;

    case CMD_GO_READY:
      goReady();
      break;

    case CMD_VAC_ON:
      vacuum_state = true;
      break;

    case CMD_VAC_OFF:
      vacuum_state = false;
      break;

    case CMD_GET_STATUS:
      sendStatus();
      break;
  }
}

void processValueCommand(uint8_t *p) {
  uint8_t cmd = p[1];
  uint8_t id = p[2];
  int value = readU16(p[3], p[4]);

  switch (cmd) {
    case CMD_SET_SPEED:
      applySpeed(id, value);
      break;

    case CMD_MOVE_SERVO:
      applyMoveServo(id, value);
      break;

    case CMD_RUN_POSE:
      applyPose(value);
      break;
  }
}

void processState() {
  switch (state) {
    case STATE_IDLE:
      break;

    case STATE_MOVE_GRASP:
      convertGraspXYZToTarget();
      if (isTargetReached()) setState(STATE_VAC_ON);
      break;

    case STATE_VAC_ON:
      vacuum_state = true;
      if (millis() - state_start_time > 500) setState(STATE_LIFT);
      break;

    case STATE_LIFT:
      applyPose(POSE_LIFT);
      if (isTargetReached()) setState(STATE_MOVE_PLACE);
      break;

    case STATE_MOVE_PLACE:
      convertPlaceXYZToTarget();
      if (isTargetReached()) setState(STATE_VAC_OFF);
      break;

    case STATE_VAC_OFF:
      vacuum_state = false;
      if (millis() - state_start_time > 300) setState(STATE_DONE);
      break;

    case STATE_DONE:
      applyPose(POSE_READY);
      if (isTargetReached()) setState(STATE_IDLE);
      break;

    case STATE_HOME:
      applyPose(POSE_HOME);
      if (isTargetReached()) setState(STATE_IDLE);
      break;

    case STATE_READY:
      applyPose(POSE_READY);
      if (isTargetReached()) setState(STATE_IDLE);
      break;

    case STATE_STOP:
      break;
  }
}

void applyPose(int pose_id) {
  if (pose_id < 0 || pose_id >= POSE_COUNT) return;

  for (int i = 0; i < SERVO_COUNT; i++) {
    target_pos[i] = pose_table[pose_id][i];
  }
}

void applySpeed(uint8_t id, int value) {
  if (value < 1) value = 1;
  if (id < SERVO_COUNT) speed_val[id] = value;
}

void applyMoveServo(uint8_t id, int value) {
  if (id < SERVO_COUNT) {
    target_pos[id] = constrain(value, 0, 1000);
  }
}

void stopAll() {
  for (int i = 0; i < SERVO_COUNT; i++) {
    target_pos[i] = current_pos[i];
  }

  vacuum_state = false;
  setState(STATE_STOP);
}

void goHome() {
  setState(STATE_HOME);
}

void goReady() {
  setState(STATE_READY);
}

void convertGraspXYZToTarget() {
  target_pos[0] = constrain(500 + gx, 0, 1000);
  target_pos[1] = constrain(500 + gy, 0, 1000);
  target_pos[2] = constrain(500 + gy, 0, 1000);
  target_pos[3] = constrain(500 + gz, 0, 1000);
  target_pos[4] = constrain(500 + gz, 0, 1000);
  target_pos[5] = constrain(grasp_angle, 0, 1000);
}

void convertPlaceXYZToTarget() {
  target_pos[0] = constrain(500 + px, 0, 1000);
  target_pos[1] = constrain(500 + py, 0, 1000);
  target_pos[2] = constrain(500 + py, 0, 1000);
  target_pos[3] = constrain(500 + pz, 0, 1000);
  target_pos[4] = constrain(500 + pz, 0, 1000);
  target_pos[5] = constrain(grasp_angle, 0, 1000);
}

void updateServo() {
  for (int i = 0; i < SERVO_COUNT - 1; i++) {
    if (current_pos[i] < target_pos[i]) {
      current_pos[i] += speed_val[i];
      if (current_pos[i] > target_pos[i]) current_pos[i] = target_pos[i];
    } else if (current_pos[i] > target_pos[i]) {
      current_pos[i] -= speed_val[i];
      if (current_pos[i] < target_pos[i]) current_pos[i] = target_pos[i];
    }

    writeServo(i, current_pos[i]);
  }
}

void updateVacuum() {
  setVacuumHardware(vacuum_state);
}

bool isTargetReached() {
  for (int i = 0; i < SERVO_COUNT - 1; i++) {
    if (current_pos[i] != target_pos[i]) return false;
  }

  return true;
}

void sendStatus() {
  uint8_t packet[4] = {ACK_START, CMD_GET_STATUS, (uint8_t)state, ACK_END};
  Serial.write(packet, 4);
}

