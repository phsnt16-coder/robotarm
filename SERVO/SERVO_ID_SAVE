from scservo_sdk import *
import time

PORT = "COM6"
BAUD = 1000000

OLD_ID = 6
NEW_ID = 7

portHandler = PortHandler(PORT)
packetHandler = scscl(portHandler)

portHandler.openPort()
portHandler.setBaudRate(BAUD)

# EEPROM Unlock
packetHandler.write1ByteTxRx(OLD_ID, 48, 0)

time.sleep(0.1)

# ID 변경
result, error = packetHandler.write1ByteTxRx(OLD_ID, 5, NEW_ID)

time.sleep(0.1)

# EEPROM Lock
packetHandler.write1ByteTxRx(NEW_ID, 48, 1)

print(f"ID 변경 명령 전송: {OLD_ID} -> {NEW_ID}")
print(f"result:{result} error:{error}")

portHandler.closePort()
