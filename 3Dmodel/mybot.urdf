<?xml version="1.0"?>
<robot name="packing_robot_corrected">

  <link name="base_link">
    <collision>
      <origin xyz="0 0 0.0325"/> <geometry>
        <box size="0.125 0.125 0.065"/>
      </geometry>
    </collision>
  </link>

  <link name="link1_shoulder_mount">
    <collision>
      <origin xyz="0 0 0.03"/> <geometry>
        <box size="0.125 0.125 0.06"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint1_base_yaw" type="revolute">
    <parent link="base_link"/>
    <child link="link1_shoulder_mount"/>
    <origin xyz="0 0 0.065"/> <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="20" velocity="2.0"/>
  </joint>

  <link name="link2_upper_arm">
    <collision>
      <origin xyz="0 0 0.06"/> <geometry>
        <box size="0.0485 0.045 0.12"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint2_shoulder" type="revolute">
    <parent link="link1_shoulder_mount"/>
    <child link="link2_upper_arm"/>
    <origin xyz="0 -0.016 0.06"/> <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="15" velocity="1.5"/>
  </joint> 



  <link name="link4_whristarm">
    <collision>
      <origin xyz="0 0 0.0775"/> <geometry>
        <box size="0.041 0.033 0.155"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint4_whrist" type="revolute">
    <parent link="link2_upper_arm"/>
    <child link="link4_whristarm"/>
    <origin xyz="0 0 0.12"/> <axis xyz="1 0 0"/>
    <limit lower="-1.57" upper="1.57" effort="15" velocity="1.5"/>
  </joint>

  <link name="link5_hand"> 
    <collision>
      <origin xyz="0.06 0 0.04"/> <geometry>
        <box size="0.078 0.026 0.126"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint5_hand" type="revolute">
    <parent link="link4_whristarm"/>
    <child link="link5_hand"/>
    <origin xyz="0 0 0.155"/> <axis xyz="1 0 0"/>
    <limit lower="-2.6" upper="2.6" effort="12" velocity="1.5"/>
  </joint>

  <link name="link6_greaper">
    <collision>
      <origin xyz="0 -0.0325 0"/> <geometry>
        <box size="0.02 0.065 0.02"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint7_greaper" type="revolute">
    <parent link="link5_hand"/>
    <child link="link6_greaper"/>
    <origin xyz="0.06 -0.013 0.065"/> <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="20" velocity="2.0"/>
  </joint>

</robot>
