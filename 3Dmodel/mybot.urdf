import pybullet as p
import pybullet_data
import time
import math

cid = p.connect(p.GUI)
p.setAdditionalSearchPath(pybullet_data.getDataPath())

# 카메라 설정
p.resetDebugVisualizerCamera(
    cameraDistance=0.5,
    cameraYaw=45,
    cameraPitch=-20,
    cameraTargetPosition=[0,0,0.1]
)

p.loadURDF("plane.urdf")

# 로봇 URDF
robot = p.loadURDF(
    r"C:\Users\phsnt\Documents\mybot.urdf",
    [0,0,0],
    useFixedBase=True,
    flags=p.URDF_USE_SELF_COLLISION
)

# 상자 URDF
cube = p.loadURDF("cube_small.urdf", [0,-0.2,0.02])

p.setGravity(0,0,-9.8)

num_joints = p.getNumJoints(robot)

sliders = []

# 슬라이더 생성
for i in range(num_joints):

    info = p.getJointInfo(robot, i)
    joint_name = info[1].decode("utf-8")

    slider = p.addUserDebugParameter(joint_name,-3.14,3.14,0)
    sliders.append(slider)


# 모든 관절 초기화
def reset_all_joints(robot):

    for j in range(p.getNumJoints(robot)):
        p.resetJointState(robot, j, 0)

    p.stepSimulation()


# 관절 범위 탐색
def find_joint_limit(robot, joint_id):

    reset_all_joints(robot)

    step = 0.02
    max_angle = 0
    min_angle = 0

    # 양의 방향 탐색
    angle = 0
    while angle < math.pi:

        p.resetJointState(robot, joint_id, angle)
        p.stepSimulation()

        contacts = p.getContactPoints(bodyA=robot, bodyB=robot)

        if contacts:
            break

        max_angle = angle
        angle += step

    # 원위치 복귀
    p.resetJointState(robot, joint_id, 0)
    p.stepSimulation()

    # 음의 방향 탐색
    angle = 0
    while angle > -math.pi:

        p.resetJointState(robot, joint_id, angle)
        p.stepSimulation()

        contacts = p.getContactPoints(bodyA=robot, bodyB=robot)

        if contacts:
            break

        min_angle = angle
        angle -= step

    p.resetJointState(robot, joint_id, 0)
    p.stepSimulation()

    print(
        "joint", joint_id,
        "range:",
        round(math.degrees(min_angle),1),
        "~",
        round(math.degrees(max_angle),1),
        "deg"
    )


print("===== 관절 실제 범위 탐색 =====")

for j in range(5):
    find_joint_limit(robot, j)
    time.sleep(0.5)

print("================================")

reset_all_joints(robot)


# 시뮬레이션 시작
while p.isConnected():

    # 팔 관절 제어
    for i in range(0,5):

        target = p.readUserDebugParameter(sliders[i])

        p.setJointMotorControl2(
            bodyUniqueId=robot,
            jointIndex=i,
            controlMode=p.POSITION_CONTROL,
            targetPosition=target,
            force=100
        )


    p.stepSimulation()
    time.sleep(1/240)

p.disconnect()
